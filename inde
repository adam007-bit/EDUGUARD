<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EduGuard AI | Advisor Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root { --primary: #4361ee; --critical: #ef233c; --warning: #ffb703; --safe: #2ec4b6; }
        body { font-family: 'Inter', sans-serif; background-color: #f8f9fa; color: #2b2d42; }
        .sidebar { background: #1b263b; color: white; min-height: 100vh; padding: 20px; }
        .stat-card { border: none; border-radius: 15px; transition: transform 0.3s; cursor: pointer; }
        .stat-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
        .bg-critical { background-color: var(--critical); color: white; }
        .bg-warning { background-color: var(--warning); color: white; }
        .bg-safe { background-color: var(--safe); color: white; }
        .student-row { transition: 0.2s; }
        .student-row:hover { background-color: #f1f3f5 !important; }
        .badge-pill { border-radius: 50px; padding: 5px 15px; }
        .search-bar { border-radius: 50px; padding-left: 20px; border: 1px solid #ddd; }
    </style>
</head>
<body>

<div class="container-fluid">
    <div class="row">
        <div class="col-md-2 sidebar d-none d-md-block">
            <h4 class="mb-5 text-center">EduGuard <b>AI</b></h4>
            <nav class="nav flex-column">
                <a class="nav-link text-white active" href="#">🏠 Dashboard</a>
                <a class="nav-link text-white-50" href="#">👥 Students</a>
                <a class="nav-link text-white-50" href="#">📊 Analytics</a>
                <a class="nav-link text-white-50" href="#">⚙️ Settings</a>
            </nav>
        </div>

        <main class="col-md-10 p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>Advisor Insights</h2>
                <input type="text" id="studentSearch" class="form-control w-25 search-bar" placeholder="Search Student ID...">
            </div>

            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="card stat-card bg-critical p-3" onclick="filterTable('CRITICAL')">
                        <h6>Critical Intervention</h6>
                        <h2 id="critCount">0</h2>
                        <small>Immediate action required</small>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card stat-card bg-warning p-3" onclick="filterTable('WARNING')">
                        <h6>Moderate Risk</h6>
                        <h2 id="warnCount">0</h2>
                        <small>Monitor closely</small>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card stat-card bg-safe p-3" onclick="filterTable('SAFE')">
                        <h6>On Track</h6>
                        <h2 id="safeCount">0</h2>
                        <small>Meeting benchmarks</small>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-lg-8">
                    <div class="card p-3 border-0 shadow-sm">
                        <h5>Live Risk Monitoring</h5>
                        <table class="table align-middle mt-3" id="riskTable">
                            <thead class="table-light">
                                <tr>
                                    <th>Student</th>
                                    <th>Quiz</th>
                                    <th>Test</th>
                                    <th>Midterm</th>
                                    <th>Risk Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody id="tableContent"></tbody>
                        </table>
                    </div>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Advisor Insights</h2>
    <div>
        <button class="btn btn-primary rounded-pill px-4 me-2" data-bs-toggle="modal" data-bs-target="#addStudentModal">+ Add Student</button>
        <input type="text" id="studentSearch" class="form-control d-inline-block search-bar" style="width: 250px;" placeholder="Search ID...">
    </div>
</div>

<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm p-4 bg-light">
            <h5><span class="me-2">🧠</span> AI Academic Analysis</h5>
            <div id="analysisText" class="text-muted mt-2">
                Analyzing current data trends...
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addStudentModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title">New Student Entry</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="addStudentForm">
                    <div class="mb-3"><input type="text" id="newName" class="form-control" placeholder="Full Name" required></div>
                    <div class="mb-3"><input type="text" id="newID" class="form-control" placeholder="Student ID (e.g. S011)" required></div>
                    <div class="row">
                        <div class="col"><input type="number" id="newQuiz" class="form-control" placeholder="Quiz %" required></div>
                        <div class="col"><input type="number" id="newTest" class="form-control" placeholder="Test %" required></div>
                        <div class="col"><input type="number" id="newMid" class="form-control" placeholder="Midterm %" required></div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" onclick="addNewStudent()">Save Student</button>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="editStudentModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Edit Maklumat Pelajar</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="editStudentForm">
                    <input type="hidden" id="editIndex">
                    <div class="mb-3"><input type="text" id="editName" class="form-control" placeholder="Nama Penuh" required></div>
                    <div class="row">
                        <div class="col"><input type="number" id="editQuiz" class="form-control" placeholder="Quiz %" required></div>
                        <div class="col"><input type="number" id="editTest" class="form-control" placeholder="Test %" required></div>
                        <div class="col"><input type="number" id="editMid" class="form-control" placeholder="Midterm %" required></div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" onclick="updateStudent()">Simpan Perubahan</button>
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
                <div class="col-lg-4">
                    <div class="card p-3 border-0 shadow-sm">
                        <h5>Class Trend Analysis</h5>
                        <canvas id="riskChart"></canvas>
                        <hr>
                        <p class="small text-muted">AI Suggestion: 3 students showed a drop in Midterm vs Test scores. Schedule a group consultation.</p>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>
<button class="btn btn-outline-success rounded-pill px-4" onclick="downloadCSV()">📗 Simpan ke Excel</button>

<script src="script.js"></script>
</body>
</html>